{
  "zscript": "#!/usr/bin/env zuzu\n\nfunction __main__() {\n\t$0\n}",
  "zmodule": "=head1 NAME\n\n${1:module/name} - ${2:short description}\n\n=cut\n\n$0",
  "zfn": "function ${1:name}(${2:args}) {\n\t$0\n}",
  "zclass": "class ${1:Name} {\n\t$0\n}",
  "zcclass": "class ${1:Name};",
  "ztrait": "trait ${1:Name} {\n\t$0\n}",
  "ztest": "say \"1..${1:1}\";\nsay \"ok 1 - ${2:description}\";\n$0",
  "zimport": "from ${1:module/name} import ${2:Symbol};",
  "ztryimport": "from ${1:module/name} try import ${2:Symbol};",
  "zpod": "=head1 ${1:NAME}\n\n$0\n\n=cut"
}
